# ALM Octane MCP Server — configuration template
# Copy this file to .env and fill in your values.
# Never commit the .env file — it contains credentials.

OCTANE_BASE_URL=https://your-octane-instance:8443
OCTANE_SHARED_SPACE_ID=1001
OCTANE_WORKSPACE_ID=1002

# Authentication — provide EITHER an API key (preferred) OR username + password.
# API key (API access key id/secret):
OCTANE_CLIENT_ID=your_api_client_id
OCTANE_CLIENT_SECRET=your_api_client_secret

# Username / password (alternative; comment out the API key pair above if used):
# OCTANE_USERNAME=your_user@example.com
# OCTANE_PASSWORD=your_password

# Optional: set to true if your Octane instance has a valid CA-signed certificate.
# Defaults to false to support on-prem instances with self-signed certificates.
OCTANE_VERIFY_SSL=false
